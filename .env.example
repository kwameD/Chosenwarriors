MINISTRY_EMAIL=chosenwarriorsofficial@gmail.com
DATABASE_PATH=data/chosen-warriors.sqlite
DATABASE_URL=
DATABASE_SSL=true
ADMIN_API_KEY=replace-with-a-long-random-secret
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Use this when the frontend is hosted separately from the Express API.
VITE_API_BASE_URL=

# SMTP credentials are required for real background email delivery.
# For Gmail, use an app password from the ministry Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=chosenwarriorsofficial@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Chosen Warriors <chosenwarriorsofficial@gmail.com>"
